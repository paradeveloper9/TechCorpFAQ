# Copy to .env and fill in values. Required variables have no defaults in Settings.

# Если используется OpenRouter, тут тоже указать ключ от OpenRouter
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-5.4-nano
OPENAI_BASE_URL=https://openrouter.ai/api/v1

OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=RAGAssistance
OPENROUTER_TIMEOUT_SECONDS=30.0

KNOWLEDGE_BASE_PATH=data/mock_kb.json
RAG_DEFAULT_TOP_K=5
